{
  "name": "@imix-js/taproot",
  "version": "1.2.0",
  "description": "AI-driven specs, enforced at commit time. Code without traceability doesn't merge.",
  "type": "module",
  "bin": {
    "taproot": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "skills/",
    "languages/",
    "docs/",
    "examples/",
    "README.md"
  ],
  "keywords": [
    "requirements",
    "traceability",
    "cli",
    "ai",
    "specs",
    "documentation"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "node --import tsx/esm src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "preflight": "bash scripts/preflight.sh",
    "release": "bash scripts/release.sh"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/imix/taproot"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@inquirer/checkbox": "^5.1.2",
    "@inquirer/confirm": "^6.0.10",
    "@inquirer/input": "^5.0.10",
    "@inquirer/select": "^5.1.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
